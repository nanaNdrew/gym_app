{
  "expo": {
    "name": "gym_app",
    "slug": "gym_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "react-native-health",
        {
          "NSHealthShareUsageDescription": "Gym App needs access to read your health data to track your progress.",
          "NSHealthUpdateUsageDescription": "Gym App needs access to write your completed workouts to Apple Health and the Fitness app."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.gym-app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.gymapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
